# ====== Required ======
# Get a token from @BotFather and paste it here.
BOT_TOKEN=
# Bot username without the @
BOT_USERNAME=
# Your Telegram user id (bootstrap superadmin).
BOT_SUPERADMIN_TG_ID=
# Storage channel chat id (negative integer, e.g. -100123456789). Bot MUST be admin there.
BOT_STORAGE_CHANNEL_ID=

# ====== Mode ======
# polling | webhook
BOT_UPDATE_MODE=polling
# Path to the welcome message file (used as initial value if DB has no welcome set)
BOT_WELCOME_MESSAGE_PATH=/app/welcome.txt

# ====== Webhook (only when BOT_UPDATE_MODE=webhook) ======
# BOT_WEBHOOK_URL=https://example.com/tg/REPLACE_WITH_SECRET
# BOT_WEBHOOK_SECRET=REPLACE_WITH_SECRET
# BOT_WEBHOOK_LISTEN=http://0.0.0.0:8080

# ====== Optional ======
BOT_DB_PATH=/app/data/bot.db
BOT_BACKUP_DIR=/app/backups
BOT_LOG_DIR=/app/logs
BOT_MEMBERSHIP_CACHE_TTL_SECONDS=300
BOT_JOB_QUEUE_CAPACITY=10000
BOT_TG_RATE_GLOBAL_PER_SEC=28
BOT_TG_RATE_PER_CHAT_PER_SEC=1
BOT_BACKUP_KEEP=14
